{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/adesolanke/gcp-financial-data-platform/schemas/usage_metric.json",
  "title": "Usage Metric",
  "description": "A usage metric event tracking customer consumption of platform resources.",
  "type": "object",
  "required": [
    "metric_id",
    "timestamp",
    "customer_id",
    "metric_type",
    "quantity",
    "unit"
  ],
  "properties": {
    "metric_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this metric event."
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of when the metric was recorded."
    },
    "customer_id": {
      "type": "string",
      "minLength": 1,
      "description": "Identifier of the customer this metric belongs to."
    },
    "metric_type": {
      "type": "string",
      "enum": ["api_calls", "tokens_processed", "compute_hours"],
      "description": "Type of usage being measured."
    },
    "quantity": {
      "type": "number",
      "minimum": 0,
      "description": "Amount of usage recorded. Must be non-negative."
    },
    "unit": {
      "type": "string",
      "minLength": 1,
      "description": "Unit of measurement (e.g., 'calls', 'tokens', 'hours')."
    }
  },
  "additionalProperties": false
}
