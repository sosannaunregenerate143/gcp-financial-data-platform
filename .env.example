# GCP Project
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1

# Pub/Sub (local emulator)
PUBSUB_EMULATOR_HOST=pubsub-emulator:8085
PUBSUB_PROJECT_ID=local-project
PUBSUB_TOPIC_VALIDATED=financial-events-validated
PUBSUB_TOPIC_DLQ=financial-events-dead-letter

# BigTable (local emulator)
BIGTABLE_EMULATOR_HOST=bigtable-emulator:8086
BIGTABLE_PROJECT_ID=local-project
BIGTABLE_INSTANCE_ID=financial-events
BIGTABLE_TABLE_ID=events

# BigQuery
BIGQUERY_PROJECT_ID=local-project
BIGQUERY_DATASET_STAGING=staging
BIGQUERY_DATASET_MARTS=marts_finance

# Ingestion Service
INGESTION_PORT=8080
INGESTION_LOG_LEVEL=debug

# Governance Service
GOVERNANCE_PORT=8081
GOVERNANCE_LOG_LEVEL=debug
GOVERNANCE_SECRET_KEY=local-dev-secret-change-in-production

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@postgres:5432/airflow
AIRFLOW__CORE__FERNET_KEY=your-fernet-key-here
AIRFLOW__CORE__DAGS_FOLDER=/opt/airflow/dags
AIRFLOW__CORE__LOAD_EXAMPLES=false
AIRFLOW__WEBSERVER__EXPOSE_CONFIG=true

# PostgreSQL (Airflow metadata)
POSTGRES_USER=airflow
POSTGRES_PASSWORD=airflow
POSTGRES_DB=airflow
